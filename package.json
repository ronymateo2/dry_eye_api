{
  "name": "dry_eye_api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy && wrangler secret bulk .env.production",
    "db:create": "wrangler d1 create weqe-db",
    "db:migrate:local": "wrangler d1 migrations apply weqe-db --local",
    "db:migrate": "wrangler d1 migrations apply weqe-db"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250409.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3",
    "wrangler": "^4.5.0"
  }
}
